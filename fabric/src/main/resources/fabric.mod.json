{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contributors": [
    "Volwert123",
    "rporotos",
    "kohari_nk",
    "sovseabird"
  ],
  "contact": {
    "email": "info@kyronis.net",
    "homepage": "${mod_homepage}",
    "issues": "${mod_github}/issues",
    "sources": "${mod_github}"
  },
  "license": "${mod_license}",
  "icon": "${mod_icon}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.kyronis.better_mcdonalds_mod.fabric.BMMFabric"
    ]
  },
  "accessWidener": "${mod_id}.classtweaker",
  "depends": {
    "java": ">=${java_version}",
    "minecraft": ">=${minecraft_version}",
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "balm": ">=${balm_version}"
  },
  "custom": {
    "modmenu": {
      "update_checker": true,
      "links": {
        "modmenu.curseforge": "https://www.curseforge.com/minecraft/mc-mods/better-mcdonalds-mod",
        "modmenu.github_releases": "${mod_github}/releases",
        "modmenu.modrinth": "https://modrinth.com/mod/better-mcdonalds-mod",
        "modmenu.wiki": "https://moddedmc.wiki/project/better-mcdonalds-mod"
      }
    }
  }
}